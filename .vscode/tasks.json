{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Raylib",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}/*.c",
                "-o",
                "${workspaceFolder}/jogo.exe",
                "-IC:/raylib-6.0_win64_mingw-w64/include",
                "-LC:/raylib-6.0_win64_mingw-w64/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}